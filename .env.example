# Copy these into the Vercel project's Environment Variables (Production).
# Do NOT commit real values.

# Passcode your phone panel must enter. Make it long + random.
PANEL_TOKEN=choose-a-long-random-passphrase

# The live app's cron secret. Must equal CRON_SECRET (or SUPERMEGA_INTERNAL_CRON_TOKEN)
# on the supermega-ytf project. This is what authorizes pipeline triggers.
CRON_TOKEN=

# Base URL of the live app. Defaults to the supermega-ytf production alias if unset.
LIVE_APP_BASE=https://supermega-ytf-swanhtet01s-projects.vercel.app

# Optional: only needed if the live deployment has Vercel Deployment Protection ON.
# Create under supermega-ytf -> Settings -> Deployment Protection -> Protection Bypass for Automation.
VERCEL_BYPASS=
